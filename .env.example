# Environment Variables for SEO and Site Configuration
# Copy this file to .env.local and update the values

# Site Domain (IMPORTANT: Update this for each site to avoid SEO issues)
# This variable is used for:
# - Canonical URLs
# - Open Graph metadata
# - Twitter metadata
# - Sitemap generation
# - Schema.org structured data
CURRENT_SITE_DOMAIN=centrotioyacu.com

# Google Maps URL for the attraction
# Update this with the correct Google Maps link for your attraction
NEXT_PUBLIC_GOOGLE_MAPS_URL=https://maps.app.goo.gl/jMkpxcSHZCNS4h1p8

# Google Maps Embed URL (optional, for embedded map)
# Update this with the correct Google Maps embed link
NEXT_PUBLIC_GOOGLE_MAPS_EMBED_URL=https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d15000!2d-77.225492!3d-6.045719!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x91b9b9b9b9b9b%3A0x0!2sCentro%20tur%C3%ADstico%20Tio%20Yacu!5e0!3m2!1sen!2sus!4v1700000000000!5m2!1sen!2sus
